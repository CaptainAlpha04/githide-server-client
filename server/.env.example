# ─── Required ────────────────────────────────────────────────────────────────

# Bearer token used by the Rust CLI to authenticate with this server.
# Generate a strong random value: openssl rand -hex 32
AUTH_TOKEN=your-strong-random-token-here

# Firebase Admin SDK service account key (JSON, single line).
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single line (remove newlines), OR leave blank and use the file method below.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# ─── Optional ─────────────────────────────────────────────────────────────────

# Port the server listens on (default: 8000)
PORT=8000

# Allowed CORS origin — set to your web app URL in production
ALLOWED_ORIGIN=http://localhost:3000

# Set to "production" to suppress detailed error messages in responses
NODE_ENV=development
